# Core local runtime
ADMIN_PASSWORD=changeme

# Shared service auth for Discord wrapper and Prism memory.
INTERNAL_SERVICE_TOKEN=replace-with-a-long-random-string
DISCORD_LATEST_KEY=$INTERNAL_SERVICE_TOKEN
PRISM_API_KEY=$INTERNAL_SERVICE_TOKEN

# Discord wrapper
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_BOT_PORT=8790
DISCORD_CHAT_HISTORY_LIMIT=12

# Downstream agent handoff for Discord mention replies.
# /api/internal/discord/chat-response forwards Discord thread/session
# context to this endpoint boundary.
DISCORD_AGENT_ENDPOINT=http://127.0.0.1:4433/api/internal/agents/discord/openclaw
DISCORD_AGENT_AUTH_TOKEN=$INTERNAL_SERVICE_TOKEN
DISCORD_AGENT_TIMEOUT_MS=30000

# Required second hop for the local OpenClaw adapter above.
# Mention replies fail with OPENCLAW_AGENT_ENDPOINT_MISSING until this is set.
OPENCLAW_AGENT_ENDPOINT=
OPENCLAW_AGENT_AUTH_TOKEN=
OPENCLAW_AGENT_MODEL=
OPENCLAW_AGENT_TIMEOUT_MS=30000

# Optional overrides
DISCORD_CHAT_RESPONSE_URL=http://127.0.0.1:4433/api/internal/discord/chat-response
PRISM_API_PORT=8788
PRISM_API_ROOT_PATH=/prism-memory
PRISM_MEMORY_BASE_URL=http://127.0.0.1:8788/prism-memory
PRISM_WORKERS_ENABLED=1
PRISM_WORKER_INTERVAL_MINUTES=30
PRISM_WORKER_INITIAL_BACKFILL_DAYS=3
PRISM_WORKER_RUN_BACKFILL_ON_START=1
PRISM_WORKER_RUN_ON_START=1
API_BASE_PATH=/api
SITE_BASE_PATH=/site
AGENT_PUBLIC_ORIGIN=
