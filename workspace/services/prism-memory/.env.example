# Prism API
PRISM_API_PORT=8788
PRISM_API_ROOT_PATH=/prism-memory
PRISM_API_KEY=
PRISM_WORKER_INTERVAL_MINUTES=30
PRISM_WORKER_INITIAL_BACKFILL_DAYS=3
PRISM_WORKER_RUN_BACKFILL_ON_START=1
PRISM_WORKER_RUN_ON_START=1

# Collectors (examples: Discord + latest meetings)
# Defaults to the local Discord wrapper when unset.
DISCORD_LATEST_URL=
# Defaults to the shared internal token when unset.
DISCORD_LATEST_KEY=
DISCORD_GUILD_ID=
# Optional heap scope for collectors that need upstream heap routing.
# Leave unset unless you enable heap-scoped collectors in config/space.json.
# SPACE_HEAP_ID=acd2cdb8-136b-4969-a578-97a17141e811
# MEETINGS_LATEST_URL configures the generic latest_meetings collector
# for meeting transcripts/summaries (not Discord-specific).
# If unset, it defaults to the example n8n webhook URL below.
MEETINGS_LATEST_URL=

# GitHub backup
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_TOKEN=
GITHUB_BRANCH=main
GITHUB_ROOT_PATH=superprism_poc/raidguild/
